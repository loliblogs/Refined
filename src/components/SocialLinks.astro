---
import type { SiteConfig } from '@/types/site-config';

interface Props {
  links: SiteConfig['links'];
}

const { links } = Astro.props;
---

{links.length > 0 && (
  <div class="mt-5">
    <div class="flex items-center justify-center">
      {links.map((link) => {
        const Icon = link.icon;
        return (
          <a
            class="
              mx-2 inline-block text-muted transition-colors duration-200
              hover:text-primary
              forced-colors:transition-none
              forced-colors:hover:text-[Highlight]
            "
            href={link.url}
            target="_blank"
            rel="noopener noreferrer"
            title={link.title}
            aria-label={link.title ?? link.url}
          >
            <Icon height="2.5rem" width="2.5rem" />
          </a>
        );
      })}
    </div>
  </div>
)}
