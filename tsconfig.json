{
  "extends": "astro/tsconfigs/strictest",
  "compilerOptions": {
    /* JSX 配置 - 使用 SolidJS */
    "jsxImportSource": "solid-js",
    /* lint .d.ts files */
    "skipLibCheck": false,
    /* 路径别名 - 简化版 */
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "plugins": [
      {
        "name": "@astrojs/ts-plugin"
      }
    ]
  }
}
